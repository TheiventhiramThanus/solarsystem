rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function: Check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function: Get user profile details
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function: Validate if user is platform administrator
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    // Helper function: Validate if user matches target company scope
    function belongsToCompany(companyId) {
      return isSignedIn() && getUserData().companyId == companyId;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin() || getUserData().companyId == resource.data.companyId);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // 2. Companies Collection
    match /companies/{companyId} {
      allow read: if isSignedIn() && (belongsToCompany(companyId) || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (belongsToCompany(companyId) && getUserData().role == 'owner') || isAdmin();
      allow delete: if isAdmin();
    }

    // 3. Checklists Collection
    match /checklists/{checklistId} {
      allow read: if isSignedIn() && (belongsToCompany(resource.data.companyId) || isAdmin());
      allow write: if isSignedIn() && (belongsToCompany(resource.data.companyId) || isAdmin());
    }

    // 4. Risks Collection
    match /risks/{riskId} {
      allow read: if isSignedIn() && (belongsToCompany(resource.data.companyId) || isAdmin());
      allow create, update: if isSignedIn() && (belongsToCompany(request.resource.data.companyId) || isAdmin());
      // SME Owners and Admins only can delete hazards
      allow delete: if isSignedIn() && ((belongsToCompany(resource.data.companyId) && getUserData().role == 'owner') || isAdmin());
    }

    // 5. Documents Collection
    match /documents/{documentId} {
      allow read: if isSignedIn() && (belongsToCompany(resource.data.companyId) || isAdmin());
      allow create: if isSignedIn() && (belongsToCompany(request.resource.data.companyId) || isAdmin());
      // SME Owners and Admins only can delete files
      allow delete: if isSignedIn() && ((belongsToCompany(resource.data.companyId) && getUserData().role == 'owner') || isAdmin());
    }

    // 6. Resources Collection
    match /resources/{resourceId} {
      allow read: if true; // Public visitors can read
      allow write: if isAdmin();
    }

    // 7. Updates Collection
    match /updates/{updateId} {
      allow read: if true; // Public visitors can read
      allow write: if isAdmin();
    }

    // 8. Feedback Collection
    match /feedback/{feedbackId} {
      allow create: if true; // Public visitors can submit feedback
      allow read, write: if isAdmin();
    }

    // 9. Activities Collection
    match /activities/{activityId} {
      allow read: if isSignedIn() && (belongsToCompany(resource.data.companyId) || isAdmin());
      allow create: if isSignedIn() && (belongsToCompany(request.resource.data.companyId) || isAdmin());
      allow update, delete: if isAdmin();
    }

    // 10. Notifications Collection
    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && (belongsToCompany(resource.data.companyId) || isAdmin());
      allow create: if isAdmin() || (isSignedIn() && belongsToCompany(request.resource.data.companyId));
      allow delete: if isAdmin();
    }
  }
}
