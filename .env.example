# ==========================================
# UK SOLAR SME COMPLIANCE TOOLKIT ENV CONFIG
# ==========================================

# ----------------------------
# 1. Frontend Config (client/)
# ----------------------------
# Rename to .env in client/ or root for loading (Vite uses VITE_ prefix)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# ----------------------------
# 2. Backend Config (server/)
# ----------------------------
PORT=5000

# Stringified JSON of the Firebase Admin service account key. 
# Obtain this in Firebase Console -> Project Settings -> Service Accounts -> Generate new private key.
# Minify/stringify the JSON file and paste it here to run real RBAC server actions.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}
